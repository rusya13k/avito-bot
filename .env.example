# H3: шаблон .env. Скопируй в .env и заполни. Файл .env в .gitignore.
#
# Эти переменные ИМЕЮТ ПРИОРИТЕТ над config.json. Можно держать
# config.json без секретов (например, с пустыми строками) и
# подкладывать их сюда — особенно удобно для prod-серверов.

# OpenAI / совместимый API
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo

# Telegram-контроллер
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# AdsPower (локальный API)
ADSPOWER_API_URL=http://local.adspower.net:50325
ADSPOWER_API_KEY=

# Логи
LOG_LEVEL=INFO
LOG_FORMAT=human
