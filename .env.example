# H3: шаблон .env. Скопируй в .env и заполни. Файл .env в .gitignore.
#
# Эти переменные ИМЕЮТ ПРИОРИТЕТ над config.json. Можно держать
# config.json без секретов (например, с пустыми строками) и
# подкладывать их сюда — особенно удобно для prod-серверов.

# DeepSeek API (или любой OpenAI-совместимый)
DEEPSEEK_API_KEY=
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-v4-flash

# Telegram-контроллер
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_ID=

# AdsPower (локальный API)
ADSPOWER_API_URL=http://localhost:50325
ADSPOWER_API_KEY=

# Логи
LOG_LEVEL=INFO
LOG_FORMAT=human
